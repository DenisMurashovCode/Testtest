global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node'
    static_configs:
      - targets:
          - '{{ web1_ip }}:9100'
          - '{{ web2_ip }}:9100'

  - job_name: 'nginxlog'
    static_configs:
      - targets:
          - '{{ web1_ip }}:9113'
          - '{{ web2_ip }}:9113'
